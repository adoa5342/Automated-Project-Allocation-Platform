  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "adm-zip": "^0.5.12",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.21.1",
